# HEAL Configuration
#
# HEAL's Claude agents use ADC: gcloud auth application-default login
#
# This .env file configures lightspeed-evaluation integration:
# - Judge LLM credentials (evaluates AI responses)
# - LLM under test (LLMUT) is configured in lscore-deploy
# - Judge's Vertex project is hard-coded in YAML config
#
# Copy to .env and fill in:
#   cp .env.example .env

# Judge LLM credentials (for lightspeed-evaluation)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Optional: Solr configuration (defaults to localhost)
# SOLR_URL=http://localhost:8983/solr/portal

# Optional: Custom paths (for development)
# OKP_MCP_ROOT=/path/to/okp-mcp
# LSCORE_DEPLOY_ROOT=/path/to/lscore-deploy
